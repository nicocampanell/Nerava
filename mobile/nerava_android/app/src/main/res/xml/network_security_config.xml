<?xml version="1.0" encoding="utf-8"?>
<!--
  Production network security config.
  HTTPS only — all cleartext traffic is rejected.
  Debug builds override this via src/debug/res/xml/network_security_config.xml
  to allow localhost / emulator-host cleartext for local dev.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
