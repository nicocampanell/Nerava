<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY network security config.
  Allows cleartext localhost / emulator-host traffic for local dev.
  This file lives in src/debug/res so it ONLY applies to debug builds.
  Release builds inherit src/main/res/xml/network_security_config.xml
  which rejects ALL cleartext traffic.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.2.127</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
