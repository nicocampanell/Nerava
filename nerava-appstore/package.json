{
  "name": "nerava-appstore",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "In-app store experience that renders inside the EVject driver shell. Nerava powers what is inside.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^24.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.2",
    "vite": "^7.2.4",
    "vitest": "^4.1.4"
  }
}
